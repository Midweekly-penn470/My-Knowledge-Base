# Shared
APP_NAME=my-knowledge-base
APP_ENV=local

# Backend
SERVER_PORT=8081
SPRING_PROFILES_ACTIVE=local
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=mykb
DB_USERNAME=mykb
DB_PASSWORD=mykb
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
APP_JWT_SECRET=change-me-to-a-long-random-secret
APP_JWT_TTL=PT12H
APP_ALLOWED_ORIGINS=http://localhost:3001

# Storage
APP_STORAGE_TYPE=LOCAL
APP_STORAGE_BUCKET=mykb-documents
APP_STORAGE_LOCAL_BASE_DIR=.runtime/storage
APP_MAX_UPLOAD_SIZE=25MB
APP_STORAGE_MAX_UPLOAD_SIZE_BYTES=26214400
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Dify
DIFY_ENABLED=true
DIFY_BASE_URL=http://127.0.0.1:8088/v1
DIFY_API_KEY=replace-me
DIFY_APP_API_KEY=replace-me
DIFY_DATASET_PERMISSION=only_me
DIFY_PROVIDER=vendor
DIFY_INDEXING_TECHNIQUE=high_quality
DIFY_POLL_INTERVAL=PT2S
DIFY_MAX_POLL_ATTEMPTS=30
DIFY_RETRIEVAL_TOP_K=5
DIFY_RETRIEVAL_MIN_SCORE=0.35
DIFY_QA_CONTEXT_MAX_CHARS=6000
DIFY_COMPLETION_TIMEOUT=PT2M
DIFY_QA_SSE_TIMEOUT=PT2M
DIFY_QA_REFUSAL_MESSAGE=No sufficiently relevant knowledge snippets were found, so the system refuses to answer this question.

# OCR
OCR_ENABLED=false
OCR_BASE_URL=http://127.0.0.1:8090
OCR_TIMEOUT=PT30S
OCR_PDF_CONTENT_TYPE=application/pdf

# Frontend
VITE_APP_NAME=My Knowledge Base
VITE_API_BASE_URL=http://localhost:8081
